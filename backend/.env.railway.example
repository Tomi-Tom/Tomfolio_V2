# Railway Environment Variables
# Set these in the Railway dashboard under your backend service > Variables

# Database — Railway provides this automatically when you add a PostgreSQL plugin
DATABASE_URL=postgresql://...

# JWT secrets — generate with: openssl rand -base64 32
JWT_SECRET=
JWT_REFRESH_SECRET=

# Google OAuth (optional — configure in Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://YOUR-RAILWAY-BACKEND.up.railway.app/api/auth/google/callback

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=onboarding@resend.dev
ADMIN_EMAIL=bariteaupeter.tom@gmail.com

# CORS — your Vercel frontend URL (comma-separated for multiple)
CORS_ORIGIN=https://your-app.vercel.app

# Node environment
NODE_ENV=production
